generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique

  email         String?
  name          String?
  phone         String?
  addressLine1  String?
  city          String?
  state         String?
  pincode       String?

  designs       Design[]

  createdAt     DateTime @default(now())
}

model Design {
  id             String   @id @default(cuid())

  prompt         String
  enhancedPrompt String?

  imageUrl       String?

  userId         String
  user           User @relation(fields: [userId], references: [id])

  orders         Order[]

  createdAt      DateTime @default(now())
}

model Order {
  id                String   @id @default(cuid())

  designId          String
  design            Design @relation(fields: [designId], references: [id])

  razorpayOrderId   String
  razorpayPaymentId String

  amount            Int

  status            String @default("PAID")

  createdAt         DateTime @default(now())

  customerName      String?
  phone             String?

  addressLine1      String?
  city              String?
  state             String?
  pincode           String?
  
  printroveOrderId  String?
  trackingNumber    String?

  color             String?
  size              String?
  variantId         Int?

  printroveStatus   String?
}